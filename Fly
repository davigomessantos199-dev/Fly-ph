local function makeRow(id: string, cf: CFrame)
    local row = Instance.new("Frame")
    row.Name = id
    row.Size = UDim2.new(1, -6, 0, 40)
    row.BackgroundColor3 = Config.Theme.Muted
    row.BorderSizePixel = 0
    row.Parent = listFrame

    local nameLbl = Instance.new("TextLabel")
    nameLbl.Size = UDim2.new(1, -220, 1, 0)
    nameLbl.Position = UDim2.new(0, 10, 0, 0)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Text = id
    nameLbl.TextColor3 = Config.Theme.Foreground
    nameLbl.Font = Enum.Font.Gotham
    nameLbl.TextSize = 14
    nameLbl.TextXAlignment = Enum.TextXAlignment.Left
    nameLbl.Parent = row

    local tpBtn = Instance.new("TextButton")
    tpBtn.Size = UDim2.new(0, 90, 0, 28)
    tpBtn.Position = UDim2.new(1, -200, 0.5, -14)
    tpBtn.BackgroundColor3 = Color3.fromRGB(70, 160, 240)
    tpBtn.TextColor3 = Color3.new(1,1,1)
    tpBtn.Text = "Teleportar"
    tpBtn.Font = Enum.Font.Gotham
    tpBtn.TextSize = 14
    tpBtn.Parent = row

    local delBtn = Instance.new("TextButton")
    delBtn.Size = UDim2.new(0, 90, 0, 28)
    delBtn.Position = UDim2.new(1, -100, 0.5, -14)
    delBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 70)
    delBtn.TextColor3 = Color3.new(1,1,1)
    delBtn.Text = "Deletar"
    delBtn.Font = Enum.Font.Gotham
    delBtn.TextSize = 14
    delBtn.Parent = row

    tpBtn.MouseButton1Click:Connect(function()
        local ok = st:TeleportTo(id)
        StarterGui:SetCore("SendNotification", {
            Title = if ok then "Teleport" else "Erro",
            Text = if ok then ("Teleportado para " .. id) else "Falha ao teleportar.",
            Duration = 2
        })
    end)

    delBtn.MouseButton1Click:Connect(function()
        if st:Remove(id) then
            row:Destroy()
            StarterGui:SetCore("SendNotification", { Title = "Removido"; Text = id; Duration = 1.5 })
            task.defer(function()
                st:SaveLocal()
            end)
        end
    end)

    return row
end

local function refreshList()
    for _, c in ipairs(listFrame:GetChildren()) do
        if c:IsA("Frame") then
            c:Destroy()
        end
    end
    local pts = st:List()
    local idx = 0
    for id, cf in pairs(pts) do
        idx += 1
        local row = makeRow(id, cf)
        row.LayoutOrder = idx
    end
    task.defer(function()
        listFrame.CanvasSize = UDim2.new(0, 0, 0, uiList.AbsoluteContentSize.Y + 12)
    end)
end

addBtn.MouseButton1Click:Connect(function()
    local id = st:AddCurrent()
    if id ~= "" then
        makeRow(id, st:List()[id])
        task.defer(function()
            listFrame.CanvasSize = UDim2.new(0, 0, 0, uiList.AbsoluteContentSize.Y + 12)
        end)
        StarterGui:SetCore("SendNotification", { Title = "Salvo"; Text = id; Duration = 1.75 })
        task.defer(function()
            st:SaveLocal()
        end)
    end
end)

