-- 4. FLY SYSTEM
-----------------------------
local function applyFlyUIState()
    if Config.Fly_Enabled then
        flyToggle.Text = "Desativar Fly"
        flyToggle.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
    else
        flyToggle.Text = "Ativar Fly"
        flyToggle.BackgroundColor3 = Color3.fromRGB(60, 180, 90)
    end
    speedLabel.Text = "Velocidade: " .. tostring(Config.Fly_Speed)
    local rel = (Config.Fly_Speed - 4) / (200 - 4)
    fill.Size = UDim2.new(math.clamp(rel, 0, 1), 0, 1, 0)
end

flyToggle.MouseButton1Click:Connect(function()
    Config.Fly_Enabled = not Config.Fly_Enabled
    if Config.Fly_Enabled then
        flyCtrl:SetSpeed(Config.Fly_Speed)
        flyCtrl:Enable()
    else
        flyCtrl:Disable()
    end
    applyFlyUIState()
end)

