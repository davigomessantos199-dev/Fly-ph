-- Atualiza UI ao spawn do personagem
local function onCharacterAdded(_char: Model)
    -- Se o Fly estava ativo e o jogador respawnou, reativa
    if Config.Fly_Enabled and not flyCtrl:IsEnabled() then
        task.wait(0.2) -- aguarda montagem do HRP
        flyCtrl:Enable()
    end
end
LocalPlayer.CharacterAdded:Connect(onCharacterAdded)
if LocalPlayer.Character then
    onCharacterAdded(LocalPlayer.Character)
end

-- Keybind para abrir/fechar a UI
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Config.KeybindToggleUI then
        toggleBtn:Activate()
    end
end)

